{
  "name": "@semantic-notes/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@semantic-notes/shared": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "chromadb": "^1.8.1",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.31.2",
    "express": "^4.19.2",
    "morgan": "^1.10.0",
    "nanoid": "^5.0.7",
    "node-cron": "^3.0.3",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.2",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.22.7",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  }
}
